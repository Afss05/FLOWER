# ============================================
# FlowerShop - Environment Configuration
# ============================================

# Multi-Tenant Configuration
CLIENT_ID=default

# ============================================
# Frontend - Customer Portal
# ============================================
VITE_API_URL=http://localhost:8000/api
VITE_APP_NAME=FlowerShop
VITE_APP_DESCRIPTION=Fresh Flowers & Pooja Items
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# ============================================
# Frontend - Admin Dashboard
# ============================================
VITE_ADMIN_API_URL=http://localhost:8000/api
VITE_ADMIN_APP_NAME=FlowerShop Admin

# ============================================
# Backend - Application
# ============================================
APP_NAME=FlowerShop
APP_ENV=local
APP_KEY=base64:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
APP_DEBUG=true
APP_URL=http://localhost:8000

# ============================================
# Backend - Database
# ============================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=flowershop_default_public
DB_USERNAME=root
DB_PASSWORD=

# ============================================
# Backend - Authentication
# ============================================
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:5174,localhost:8000
SANCTUM_DOMAIN=localhost
SESSION_DOMAIN=localhost

# ============================================
# Backend - Mail Configuration
# ============================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_ENCRYPTION=tls
MAIL_FROM_NAME="FlowerShop"
MAIL_FROM_ADDRESS=noreply@flowershop.local

# ============================================
# Backend - Razorpay Payment Gateway
# ============================================
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxx

# ============================================
# Backend - Queue & Caching
# ============================================
QUEUE_CONNECTION=database
CACHE_DRIVER=file
SESSION_DRIVER=database

# ============================================
# Backend - Logging
# ============================================
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ============================================
# Backend - Third-Party Services
# ============================================
# SMS Service (for OTP)
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=your_account_sid
SMS_AUTH_TOKEN=your_auth_token
SMS_FROM_NUMBER=+1234567890

# ============================================
# Multi-Tenancy Configuration
# ============================================
TENANT_COLUMN=tenant_id
TENANT_DATABASE_HOST=127.0.0.1
TENANT_DATABASE_PORT=3306

# ============================================
# Redis (Optional - for caching/sessions)
# ============================================
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================
# Development Features
# ============================================
TELESCOPE_ENABLED=false
HORIZON_ENABLED=false
