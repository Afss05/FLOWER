# Node.js Environment
NODE_ENV=development
PORT=8000

# Client Configuration
CLIENT_ID=default

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=flowershop_default_public

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=7d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Email (Mailtrap/SendGrid)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=xxxxx
MAIL_PASSWORD=xxxxx
MAIL_FROM=noreply@flowershop.local

# File Upload
UPLOAD_DIR=./storage/uploads
MAX_FILE_SIZE=10485760

# Business Hours
BUSINESS_OPEN_TIME=06:00
BUSINESS_CLOSE_TIME=22:00
NEXT_DAY_DELIVERY_TIME=10:00
SAME_DAY_DELIVERY_DEADLINE=18:00
