{
  "name": "@flowershop/backend",
  "version": "1.0.0",
  "description": "FlowerShop Node.js REST API Backend",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --no-warnings=DEP0180 --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "db:migrate": "node --loader ts-node/esm src/database/migrate.ts",
    "db:seed": "node --loader ts-node/esm src/database/seed.ts",
    "db:reset": "node --loader ts-node/esm src/database/reset.ts"
  },
  "keywords": [
    "flowershop",
    "express",
    "typescript",
    "rest-api"
  ],
  "author": "FlowerShop Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "sequelize": "^6.35.1",
    "mysql2": "^3.6.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "zod": "^3.22.4",
    "axios": "^1.6.2",
    "razorpay": "^2.9.2",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.0",
    "slugify": "^1.6.6",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "compression": "^1.7.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/jest": "^29.5.11",
    "@types/multer": "^1.4.11",
    "@types/uuid": "^9.0.7",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/morgan": "^1.9.9",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcryptjs": "^2.4.6",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "prettier": "^3.8.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1"
  }
}
