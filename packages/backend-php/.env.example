# App
APP_ENV=development
APP_NAME=FlowerShop
APP_URL=http://localhost:8080
CLIENT_ID=default

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=flowershop
DB_USER=root
DB_PASS=

# JWT — MUST be at least 32 random characters
JWT_SECRET=change_this_to_a_32_char_or_longer_random_secret
JWT_EXPIRES_IN=604800

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Rate Limiting (requests per window per IP)
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=60

# Mail (optional)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@flowershop.com
MAIL_FROM_NAME=FlowerShop

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Upload
UPLOAD_MAX_SIZE=5242880
UPLOAD_PATH=storage/uploads
