{
    "name": "flowershop/backend-php",
    "description": "FlowerShop PHP/MySQL REST API Backend",
    "type": "project",
    "require": {
        "php": "^8.2",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "firebase/php-jwt": "^7.0",
        "vlucas/phpdotenv": "^5.6",
        "respect/validation": "^2.3",
        "monolog/monolog": "^3.5",
        "phpmailer/phpmailer": "^6.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8080 -t public",
        "migrate": "php database/migrate.php",
        "seed": "php database/seed.php",
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true
    }
}
